{
	"$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
	"plugins": ["./tools/biome/no-setstate-updater-side-effects.grit"],
	"files": {
		"includes": [
			"**",
			"!.sandcastle",
			"!.turbo",
			"!apps/legacy",
			"!**/node_modules",
			"!**/dist",
			"!**/build",
			"!**/*.generated.*"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single",
			"trailingCommas": "all"
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"style": {
				"useFilenamingConvention": {
					"level": "error",
					"options": {
						"strictCase": true,
						"requireAscii": true,
						"filenameCases": ["kebab-case"]
					}
				},
				"useImportType": "error"
			},
			"correctness": {
				"noUnusedImports": "error",
				"noUnusedVariables": "error"
			}
		}
	},
	"assist": {
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	}
}
