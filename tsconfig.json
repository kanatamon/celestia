{
	"extends": "./tsconfig.base.json",
	"compilerOptions": {
		"types": ["node"],
		"noEmit": true,
		"paths": {
			"@celestia/tiktok-live-core": ["./packages/tiktok-live-core/src/index.ts"],
			"@celestia/tiktok-live-chrome-extension": [
				"./packages/tiktok-live-chrome-extension/src/index.ts"
			]
		}
	},
	"include": [
		".sandcastle/**/*.mts",
		"packages/*/src/**/*.ts",
		"packages/*/tests/**/*.ts",
		"apps/*/src/**/*.ts",
		"apps/*/tests/**/*.ts"
	],
	"exclude": ["node_modules", "apps/legacy"]
}
