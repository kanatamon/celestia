{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"outDir": "dist",
		"rootDir": "../..",
		"jsx": "react-jsx",
		"types": ["chrome", "vite/client", "vitest/globals"],
		"paths": {
			"@celestia/tiktok-live-core": ["../../packages/tiktok-live-core/src/index.ts"],
			"@celestia/tiktok-live-chrome-extension": [
				"../../packages/tiktok-live-chrome-extension/src/index.ts"
			],
			"@celestia/ui": ["../../packages/ui/src/index.ts"]
		}
	},
	"include": [
		"gift-tap-classic-injection.ts",
		"manifest.config.ts",
		"vite.config.ts",
		"vitest.e2e.config.ts",
		"src/**/*.d.ts",
		"src/**/*.ts",
		"src/**/*.tsx",
		"tests/**/*.ts",
		"tests/**/*.tsx"
	]
}
