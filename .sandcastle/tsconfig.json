{
	"compilerOptions": {
		"strict": true,
		"target": "ES2022",
		"lib": ["ES2025", "DOM"],
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"verbatimModuleSyntax": true,
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"resolveJsonModule": true,
		"noUncheckedIndexedAccess": true,
		"noImplicitOverride": true,
		"skipLibCheck": true,
		"types": ["node"]
	},
	"include": ["*.mts"]
}
