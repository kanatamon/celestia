// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  userId            String   @id
  secUid            String
  uniqueId          String?
  nickname          String?
  profilePictureUrl String?
  followRole        Int?
  userSceneTypes    Json // Array of numbers
  isModerator       Boolean  @default(false)
  isNewGifter       Boolean  @default(false)
  isSubscriber      Boolean  @default(false)
  topGifterRank     Int?
  gifterLevel       Int      @default(0)
  teamMemberLevel   Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  followInfo     FollowInfo?
  chatMessages   WebcastChatMessage[]
  memberMessages WebcastMemberMessage[]
  likeMessages   WebcastLikeMessage[]
  giftMessages   WebcastGiftMessage[]

  @@map("users")
}

model FollowInfo {
  id             String   @id
  followingCount Int      @default(0)
  followerCount  Int      @default(0)
  followStatus   Int      @default(0)
  pushStatus     Int      @default(0)
  userId         String   @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@map("follow_info")
}

model WebcastLiveIntroMessage {
  id               String   @id
  roomId           String
  description      String?
  streamerUniqueId String
  createdAt        DateTime @default(now())

  @@map("webcast_live_intro_messages")
}

model WebcastChatMessage {
  id         String   @id
  roomId     String
  msgId      String   @unique
  comment    String?
  emotes     Json // Array of any
  createTime String
  userId     String
  createdAt  DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@map("webcast_chat_messages")
}

model WebcastRoomUserSeqMessage {
  id          String   @id
  roomId      String
  viewerCount Int      @default(0)
  createdAt   DateTime @default(now())

  @@map("webcast_room_user_seq_messages")
}

model WebcastMemberMessage {
  id          String   @id
  roomId      String
  msgId       String   @unique
  actionId    Int
  createTime  String
  displayType String
  label       String
  userId      String
  createdAt   DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@map("webcast_member_messages")
}

model WebcastLikeMessage {
  id             String   @id
  roomId         String
  msgId          String   @unique
  likeCount      Int      @default(0)
  totalLikeCount Int      @default(0)
  createTime     String
  displayType    String
  label          String
  userId         String
  createdAt      DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@map("webcast_like_messages")
}

model WebcastGiftMessage {
  id             String   @id @default(uuid())
  roomId         String
  msgId          String   @unique
  giftId         Int
  repeatCount    Int      @default(0)
  groupId        String
  createTime     String
  displayType    String
  label          String
  repeatEnd      Boolean  @default(false)
  describe       String
  giftType       Int      @default(0)
  diamondCount   Int      @default(0)
  giftName       String
  giftPictureUrl String
  timestamp      BigInt
  receiverUserId String
  userId         String
  createdAt      DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@map("webcast_gift_messages")
}
