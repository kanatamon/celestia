// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  userId            String   @id
  secUid            String
  uniqueId          String?
  nickname          String
  profilePictureUrl String?
  followRole        Int?
  userSceneTypes    Json // Array of numbers
  isModerator       Boolean  @default(false)
  isNewGifter       Boolean  @default(false)
  isSubscriber      Boolean  @default(false)
  topGifterRank     Int?
  gifterLevel       Int      @default(0)
  teamMemberLevel   Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  userBadges       UserBadge[]
  userDetails      UserDetails?
  followInfo       FollowInfo?
  chatMessages     WebcastChatMessage[]
  memberMessages   WebcastMemberMessage[]
  likeMessages     WebcastLikeMessage[]
  giftMessages     WebcastGiftMessage[]
  topViewerEntries TopViewer[]

  @@map("users")
}

model UserBadge {
  id             String   @id
  type           String
  badgeSceneType Int?
  displayType    Int?
  url            String?
  privilegeId    String?
  level          Int?
  name           String?
  userId         String
  createdAt      DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@map("user_badges")
}

model UserDetails {
  id                 String   @id
  createTime         String
  bioDescription     String
  profilePictureUrls Json? // Array of strings
  userId             String   @unique
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@map("user_details")
}

model FollowInfo {
  id             String   @id
  followingCount Int      @default(0)
  followerCount  Int      @default(0)
  followStatus   Int      @default(0)
  pushStatus     Int      @default(0)
  userId         String   @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@map("follow_info")
}

model WebcastLiveIntroMessage {
  id                String   @id
  roomId            String
  description       String
  userId            String
  secUid            String
  nickname          String
  profilePictureUrl String
  userBadges        Json // Array of UserBadge objects
  userSceneTypes    Json // Array of numbers
  userDetails       Json // UserDetails object
  isModerator       Boolean  @default(false)
  isNewGifter       Boolean  @default(false)
  isSubscriber      Boolean  @default(false)
  topGifterRank     Int?
  gifterLevel       Int      @default(0)
  teamMemberLevel   Int      @default(0)
  createdAt         DateTime @default(now())

  @@map("webcast_live_intro_messages")
}

model WebcastChatMessage {
  id         String   @id
  roomId     String
  msgId      String   @unique
  comment    String?
  emotes     Json // Array of any
  createTime String
  userId     String
  createdAt  DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@map("webcast_chat_messages")
}

model WebcastRoomUserSeqMessage {
  id          String   @id
  roomId      String
  viewerCount Int      @default(0)
  createdAt   DateTime @default(now())

  // Relations
  topViewers TopViewer[]

  @@map("webcast_room_user_seq_messages")
}

model TopViewer {
  id                          String   @id
  coinCount                   Int      @default(0)
  userId                      String
  webcastRoomUserSeqMessageId String?
  createdAt                   DateTime @default(now())

  // Relations
  user                      User                       @relation(fields: [userId], references: [userId], onDelete: Cascade)
  webcastRoomUserSeqMessage WebcastRoomUserSeqMessage? @relation(fields: [webcastRoomUserSeqMessageId], references: [id], onDelete: Cascade)

  @@map("top_viewers")
}

model WebcastMemberMessage {
  id          String   @id
  roomId      String
  msgId       String   @unique
  actionId    Int
  createTime  String
  displayType String
  label       String
  userId      String
  createdAt   DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@map("webcast_member_messages")
}

model WebcastLikeMessage {
  id             String   @id
  roomId         String
  msgId          String   @unique
  likeCount      Int      @default(0)
  totalLikeCount Int      @default(0)
  createTime     String
  displayType    String
  label          String
  userId         String
  createdAt      DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@map("webcast_like_messages")
}

model Gift {
  id           String   @id
  gift_id      Int
  repeat_count Int      @default(0)
  repeat_end   Int      @default(0)
  gift_type    Int      @default(0)
  createdAt    DateTime @default(now())

  // Relations
  giftMessages WebcastGiftMessage[]

  @@map("gifts")
}

model WebcastGiftMessage {
  id             String   @id
  roomId         String
  msgId          String   @unique
  giftId         Int
  repeatCount    Int      @default(0)
  groupId        String
  createTime     String
  displayType    String
  label          String
  repeatEnd      Boolean  @default(false)
  describe       String
  giftType       Int      @default(0)
  diamondCount   Int      @default(0)
  giftName       String
  giftPictureUrl String
  timestamp      BigInt
  receiverUserId String
  userId         String
  giftModelId    String?
  createdAt      DateTime @default(now())

  // Relations
  user User  @relation(fields: [userId], references: [userId], onDelete: Cascade)
  gift Gift? @relation(fields: [giftModelId], references: [id], onDelete: SetNull)

  @@map("webcast_gift_messages")
}
